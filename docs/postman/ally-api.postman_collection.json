{
  "info": {
    "_postman_id": "ally-api-collection",
    "name": "Ally",
    "description": "Complete API collection for the Ally personal AI companion backend.\n\nSetup:\n1. Import the ally-local environment\n2. Set jwtSecret and webhookSecret to match your .env\n3. Run the \"Generate Auth Token\" request first to populate authToken\n4. All authenticated requests will use the token automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-refresh token if expired or missing",
          "const token = pm.environment.get('authToken');",
          "if (!token) {",
          "  console.log('No authToken set. Run the Generate Auth Token request first.');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "v1",
      "description": "The V1 of the Ally API",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Generate Auth Token",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// This generates a JWT locally for testing.",
                      "// In production, tokens come from your auth provider.",
                      "//",
                      "// Since Postman can't sign JWTs natively, use this curl command instead:",
                      "// See docs/MANUAL_TESTING.md for the curl/bun approach to generate tokens."
                    ]
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/health",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "health"
                  ]
                },
                "description": "Placeholder — JWT generation requires a script outside Postman.\n\nGenerate a token using the helper script described in docs/MANUAL_TESTING.md, then paste it into the authToken environment variable."
              }
            }
          ]
        },
        {
          "name": "Health",
          "item": [
            {
              "name": "Health Check",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/health",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "health"
                  ]
                },
                "description": "Public health check endpoint. Returns API status, uptime, version, and database connectivity."
              }
            }
          ]
        },
        {
          "name": "Chat",
          "item": [
            {
              "name": "Send Message (non-streaming)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json.conversationId) {",
                      "  pm.environment.set('conversationId', json.conversationId);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{authToken}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"message\": \"Hey Ally, how are you today?\",\n  \"stream\": false\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/chat",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "chat"
                  ]
                },
                "description": "Send a chat message and receive the full response at once.\n\nThe conversationId is auto-saved to the environment for follow-up messages."
              }
            },
            {
              "name": "Send Message (streaming SSE)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{authToken}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"message\": \"Tell me something encouraging\",\n  \"stream\": true\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/chat",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "chat"
                  ]
                },
                "description": "Send a chat message with SSE streaming.\n\nPostman shows the raw SSE text. For a better experience, use curl:\n\ncurl -N -X POST http://localhost:3000/api/v1/chat \\\n  -H 'Content-Type: application/json' \\\n  -H 'Authorization: Bearer YOUR_TOKEN' \\\n  -d '{\"message\": \"Tell me something encouraging\", \"stream\": true}'"
              }
            },
            {
              "name": "Continue Conversation",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{authToken}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"message\": \"Thanks! Can you tell me more?\",\n  \"conversationId\": \"{{conversationId}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/chat",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "chat"
                  ]
                },
                "description": "Continue an existing conversation. Uses the conversationId saved from a previous chat request."
              }
            }
          ]
        },
        {
          "name": "Onboarding",
          "item": [
            {
              "name": "Submit Onboarding",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{authToken}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"answers\": {\n    \"nameAndGreeting\": \"I'm Alex, you can call me Al\",\n    \"lifeContext\": \"Software engineer at a startup in SF\",\n    \"currentFocus\": \"Getting promoted and training for a half marathon\",\n    \"stressAndSupport\": \"Work deadlines stress me out. I cope by running.\",\n    \"allyExpectations\": \"A friend who remembers things and checks in\"\n  }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/onboarding",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "onboarding"
                  ]
                },
                "description": "Complete user onboarding. Creates a memory profile from the answers."
              }
            }
          ]
        },
        {
