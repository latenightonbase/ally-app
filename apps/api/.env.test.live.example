DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST/neondb?sslmode=require
JWT_SECRET=test-jwt-secret-for-testing-only
WEBHOOK_SECRET=test-webhook-secret
ANTHROPIC_API_KEY=sk-ant-YOUR-REAL-KEY
VOYAGE_API_KEY=pa-YOUR-REAL-KEY
NODE_ENV=test
PORT=3001

# Public HTTPS join page (same origin as the API is fine). Used for /invite/:token and inviteLink in family invites.
INVITE_WEB_BASE_URL=https://your-api-host.example
IOS_APP_STORE_URL=https://apps.apple.com/app/id0000000000
ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.anonymous.allyapp

# Apple Universal Links (host AASA on this API at /.well-known/apple-app-site-association)
APPLE_TEAM_ID=
IOS_BUNDLE_ID=

# Android App Links (host assetlinks on this API at /.well-known/assetlinks.json)
ANDROID_ASSETLINKS_PACKAGE=
ANDROID_ASSETLINKS_SHA256=

# Mobile EAS build: hostname only, must match INVITE_WEB_BASE_URL host (set at build time)
# EXPO_PUBLIC_INVITE_HOST=your-api-host.example
